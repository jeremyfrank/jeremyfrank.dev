---
import BaseLayout from '@/layouts/BaseLayout.astro'

const { canonicalURL } = Astro.props

const title = [Astro.props.title, Astro.props.content?.title]
  .filter(Boolean)
  .join()

const byline = [Astro.props.byline, Astro.props.content?.byline]
  .filter(Boolean)
  .join()
---

<BaseLayout title={title} canonicalURL={canonicalURL}>
  <div class="wrapper flow prose subgrid gc-full">
    <h1>
      {title}
    </h1>

    {byline && <p class="byline">{byline}</p>}
    <slot />
  </div>
</BaseLayout>

<style>
  .wrapper {
    padding-bottom: 10vh;
  }

  .byline {
    font-style: italic;
    line-height: 1.25;
    text-wrap: pretty;
  }
</style>
