---
type Props = {
  src: string
  bordered?: boolean
  width?: number | null
  caption?: string
}

const { src, bordered = false, width, caption } = Astro.props
---

<figure>
  <video
    width={width}
    class:list={{ bordered: bordered }}
    controls
    autoplay
    loop
  >
    <source src={src} type="video/mp4" />
  </video>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  video {
    &.bordered {
      border: 1px solid var(--text-color);
    }
  }
</style>
